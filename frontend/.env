# Development environment variables
# All VITE_ prefixed vars are exposed to the browser bundle

# Backend API base URL (dev uses Vite proxy, so path-only is fine too)

VITE_API_URL=http://192.168.10.76:5002/api/v1

# App metadata
VITE_APP_TITLE=Drishti Reports
VITE_APP_VERSION=1.0.0

# Polling interval (ms) for async/background report jobs
VITE_POLL_INTERVAL_MS=3000
