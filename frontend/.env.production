# Production environment variables
# Loaded automatically by Vite during `vite build`

# Relative path — Nginx/reverse-proxy forwards /api to the backend
VITE_API_URL=/api/v1

# App metadata
VITE_APP_TITLE=Drishti Reports
VITE_APP_VERSION=1.0.0

# Polling interval (ms) for async/background report jobs
VITE_POLL_INTERVAL_MS=3000
