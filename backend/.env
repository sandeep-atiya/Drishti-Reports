NODE_ENV=production
PORT=5001

# MSSQL - Connection method: Use INSTANCE-BASED or DYNAMIC PORT
# For Default Instance (MSSQLSERVER): use instanceName=MSSQLSERVER
# For Named Instance (MSSQLSERVER19): use instanceName=MSSQLSERVER19
MSSQL_HOST=192.168.10.177
# If SQL Server uses named instance, use instanceName instead of port
MSSQL_INSTANCE=MSSQLSERVER
# Only set port if you've explicitly configured SQL Server to use static port 1433
# MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD='Atiya@#$&!2025@#'
MSSQL_DB=DristhiSoftTechDB
MSSQL_DIALECT=mssql
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true
MSSQL_POOL_MAX=100
MSSQL_POOL_MIN=10
MSSQL_POOL_IDLE=60000
MSSQL_REQUEST_TIMEOUT=30000
MSSQL_CONNECTION_TIMEOUT=15000

# ==================================================
# Redis Configuration (for rate-limit store / caching)
# ==================================================
REDIS_HOST=redis-18695.c261.us-east-1-4.ec2.cloud.redislabs.com
REDIS_PORT=18695
REDIS_PASSWORD=Lmmnupi29ooGRUGjyEbpZ3JLb3DKAbKd
REDIS_USER=default
REDIS_DB=0


# Async threshold: ranges > this many days are processed as background jobs
LARGE_RANGE_DAYS=90

# How often to re-sync SQLite from PG + MSSQL (in minutes)
SYNC_INTERVAL_MINUTES=60

# JWT Authentication
JWT_SECRET=Drishti@Reports#SecretKey!2025$
JWT_EXPIRES_IN=8h

# AES (matches ASP.NET Rfc2898DeriveBytes encryption used for passwords)
AES_KEY=ThisIsAKeyForEncryptAndDecryptTheText
AES_SALT=49,76,61,6e,20,4d,65,64,76,65,64,65,76

# PostgreSQL
PG_HOST=192.168.3.233
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD='Atiya@123#'
PG_DB=reportsdb
PG_DIALECT=postgres
PG_POOL_MAX=100
PG_POOL_MIN=10
PG_POOL_IDLE=60000
