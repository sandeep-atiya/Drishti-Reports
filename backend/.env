NODE_ENV=development
PORT=5000

# MSSQL
MSSQL_HOST=192.168.10.177
MSSQL_PORT=1433
MSSQL_USER=DevTeam
MSSQL_PASSWORD="Atiya@#!#123#@"
MSSQL_DB=DristhiSoftTechDB_Development
MSSQL_DIALECT=mssql
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true
MSSQL_POOL_MAX=100
MSSQL_POOL_MIN=10
MSSQL_POOL_IDLE=60000

# Redis (for caching + BullMQ jobs)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password   # uncomment if Redis has auth
REDIS_PASSWORD=
# Async threshold: ranges > this many days are processed as background jobs
LARGE_RANGE_DAYS=90

# How often to re-sync SQLite from PG + MSSQL (in minutes)
SYNC_INTERVAL_MINUTES=60

# PostgreSQL
PG_HOST=192.168.3.233
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD="Atiya@123#"
PG_DB=reportsdb
PG_DIALECT=postgres
PG_POOL_MAX=100
PG_POOL_MIN=10
PG_POOL_IDLE=60000
