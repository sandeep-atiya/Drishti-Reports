<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- iisnode handler — path must match the rewrite target exactly -->
    <handlers>
      <add name="iisnode" path="src/server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- Rewrite all requests to the Node.js entry point -->
    <rewrite>
      <rules>
        <rule name="DrishtiReportsPool" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="src/server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Pass Express responses through unchanged -->
    <httpErrors existingResponse="PassThrough" />

    <webSocket enabled="true" />

    <iisnode
      loggingEnabled="true"
      logDirectory="logs\iisnode"
      devErrorsEnabled="true"
      nodeProcessCountPerApplication="2"
      maxConcurrentRequestsPerProcess="4096"
    />

  </system.webServer>
</configuration>
