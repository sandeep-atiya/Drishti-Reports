  "main": "./src/server.js",
  "scripts": {
    "dev": "nodemon ./src/server.js",
    "start": "node ./src/server.js",
    "clean:redis": "node ./scripts/flush-redis.js",
    "clean:sqlite": "node ./scripts/truncate-sqlite.js",
